# =============================================================================
# Frontend env (Vite) — copy to ".env" and fill in real values.
# Only VITE_* variables are exposed to the browser bundle.
# Never put service_role or cron secrets here.
# Full guide: docs/configuration.md
# =============================================================================

# Supabase project URL (Dashboard → Project Settings → API → Project URL)
# Example: https://abcdefgh.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon / publishable key (Dashboard → API → anon public)
# Safe for the browser; Row Level Security still applies.
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional — Cloudflare Turnstile site key (public).
# Leave empty for local Sign up without captcha (dev bypass).
# Pair with TURNSTILE_SECRET_KEY on Supabase Edge Function secrets in production.
VITE_TURNSTILE_SITE_KEY=

# -----------------------------------------------------------------------------
# NOT used by the Vite app — set these elsewhere:
#   RESET_CRON_SECRET          → GitHub Actions + Supabase Edge Function secrets
#   SUPABASE_SERVICE_ROLE_KEY  → GitHub Actions only (keep-alive / admin jobs)
#   TURNSTILE_SECRET_KEY       → Supabase Edge Function secrets
# -----------------------------------------------------------------------------
